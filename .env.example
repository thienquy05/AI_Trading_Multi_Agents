ENVIRONMENT=development

# Schema-owning role (Alembic migrations / DDL)
POSTGRES_USER=trading_app
POSTGRES_PASSWORD=changeme
# Least-privilege runtime role (created by migration 0004; the backend connects as this)
POSTGRES_APP_USER=trading_runtime
POSTGRES_APP_PASSWORD=changeme
POSTGRES_DB=trading
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

BACKEND_PORT=5000

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_TTL_MINUTES=30

# The only browser origin allowed by CORS
FRONTEND_ORIGIN=http://localhost:3000

# Failed-login lockout: after LOGIN_MAX_FAILURES failures, /auth/login
# answers 429 until the window expires
LOGIN_MAX_FAILURES=5
LOGIN_FAILURE_WINDOW_SECONDS=300

# Read by `python -m app.cli seed-operator` (leave unset to be prompted)
# OPERATOR_USERNAME=
# OPERATOR_PASSWORD=
